      "code": "1.1",
      "fullLabel": "1.1 Browsing, Searching and Filtering Data, Information and Digital Content",
      "name": "Browsing, Searching and Filtering Data, Information and Digital Content",
      "group": "Information and Data Literacy",
      "groupNr": 1,
      "description": "To articulate information needs , to search for data, information and content in digital environments, to access them and to navigate between them. to create and update personal search strategies."
    },
    {
      "code": "1.2",
      "fullLabel": "1.2 Evaluating Data, Information and Digital Content",
      "name": "Evaluating Data, Information and Digital Content",
      "group": "Information and Data Literacy",
      "groupNr": 1,
      "description": "To analyse, compare and critically evaluate the credibility and reliability of sources of data, information and digital content. to analyse, interpret and critically evaluate the data, information and digital content."
    },
    {
      "code": "1.3",
      "fullLabel": "1.3 Managing Data, Information and Digital Content",
      "name": "Managing Data, Information and Digital Content",
      "group": "Information and Data Literacy",
      "groupNr": 1,
      "description": "To organise, store and retrieve data, information, and content in digital environments. to organise and process them in a structured environment."
    },
    {
      "code": "2.1",
      "fullLabel": "2.1 Interacting Through Digital Technologies",
      "name": "Interacting Through Digital Technologies",
      "group": "Communication and Collaboration",
      "groupNr": 2,
      "description": "To interact through a variety of digital technologies and to understand appropriate digital communication means for a given context."
    },
    {
      "code": "2.2",
      "fullLabel": "2.2 Sharing Through Digital Technologies",
      "name": "Sharing Through Digital Technologies",
      "group": "Communication and Collaboration",
      "groupNr": 2,
      "description": "To share data, information and digital content with others through appropriate digital technologies. to act as an intermediary, to know about referencing and attribution practices."
    },
    {
      "code": "2.3",
      "fullLabel": "2.3 Engaging Citizenship Through Digital Technologies",
      "name": "Engaging Citizenship Through Digital Technologies",
      "group": "Communication and Collaboration",
      "groupNr": 2,
      "description": "To participate in society through the use of public and private digital services. to seek opportunities for self-empowerment and for participatory citizenship through appropriate digital technologies."
    },
    {
      "code": "2.4",
      "fullLabel": "2.4 Collaborating Through Digital Technologies",
      "name": "Collaborating Through Digital Technologies",
      "group": "Communication and Collaboration",
      "groupNr": 2,
      "description": "To use digital tools and technologies for collaborative processes, and for co-construction and co-creation of data, resources and knowledge."
    },
    {
      "code": "2.5",
      "fullLabel": "2.5 Netiquette",
      "name": "Netiquette",
      "group": "Communication and Collaboration",
      "groupNr": 2,
      "description": "To be aware of behavioural norms and know-how while using digital technologies and interacting in digital environments. to adapt communication strategies to the specific audience and to be aware of cultural and generational diversity in digital environments"
    },
    {
      "code": "2.6",
      "fullLabel": "2.6 Managing Digital Identity",
      "name": "Managing Digital Identity",
      "group": "Communication and Collaboration",
      "groupNr": 2,
      "description": "To create, and manage one or multiple digital identities, to be able to protect one's own reputation, to deal with the data that one produces through several digital tools, environments and services."
    },
    {
      "code": "3.1",
      "fullLabel": "3.1 Developing Digital Content",
      "name": "Developing Digital Content",
      "group": "Digital Content Creation",
      "groupNr": 3,
      "description": "To create and edit digital content in different formats, to express oneself through digital means"
    },
    {
      "code": "3.2",
      "fullLabel": "3.2 Integrating and Re-Elaborating Digital Content",
      "name": "Integrating and Re-Elaborating Digital Content",
      "group": "Digital Content Creation",
      "groupNr": 3,
      "description": "To modify, refine and integrate new information and content into an existing body of knowledge and resources to create new, original and relevant content and knowledge."
    },
    {
      "code": "3.3",
      "fullLabel": "3.3 Copyright and Licences",
      "name": "Copyright and Licences",
      "group": "Digital Content Creation",
      "groupNr": 3,
      "description": "To understand how copyright and licences apply to digital information and content."
    },
    {
      "code": "3.4",
      "fullLabel": "3.4 Programming",
      "name": "Programming",
      "group": "Digital Content Creation",
      "groupNr": 3,
      "description": "To plan and develop a sequence of understandable instructions for a computing system to solve a given problem or to perform a specific task."
    },
    {
      "code": "4.1",
      "fullLabel": "4.1 Protecting Devices",
      "name": "Protecting Devices",
      "group": "Safety",
      "groupNr": 4,
      "description": "To protect devices and digital content, and to understand risks and threats in digital environments.to know about safety and security measures and to have a due regard to reliability and privacy."
    },
    {
      "code": "4.2",
      "fullLabel": "4.2 Protecting Personal Data and Privacy",
      "name": "Protecting Personal Data and Privacy",
      "group": "Safety",
      "groupNr": 4,
      "description": "To protect personal data and privacy in digital environments. to understand how to use and share personally identifiable information while being able to protect oneself and others from damages. to understand that digital services use a “Privacy policy” to inform how personal data is used."
    },
    {
      "code": "4.3",
      "fullLabel": "4.3 Protecting Health and Well-Being",
      "name": "Protecting Health and Well-Being",
      "group": "Safety",
      "groupNr": 4,
      "description": "To be able to avoid health-risks and threats to physical and psychological well-being while using digital technologies. to be able to protect oneself and others from possible dangers in digital environments (e.g. cyber bullying). to be aware of digital technologies for social well-being and social inclusion."
    },
    {
      "code": "4.4",
      "fullLabel": "4.4 Protecting the Environment",
      "name": "Protecting the Environment",
      "group": "Safety",
      "groupNr": 4,
      "description": "To be aware of the environmental impact of digital technologies and their use."
    },
    {
      "code": "5.1",
      "fullLabel": "5.1 Solving Technical Problems",
      "name": "Solving Technical Problems",
      "group": "Problem Solving",
      "groupNr": 5,
      "description": "To identify technical problems when operating devices and using digital environments, and to solve them (from trouble-shooting to solving more complex problems)."
    },
    {
      "code": "5.2",
      "fullLabel": "5.2 Identifying Needs and Technological Responses",
      "name": "Identifying Needs and Technological Responses",
      "group": "Problem Solving",
      "groupNr": 5,
      "description": "To assess needs and to identify, evaluate, select and use digital tools and possible technological responses and to solve them. to adjust and customise digital environments to personal needs (e.g. accessibility)."
    },
    {
      "code": "5.3",
      "fullLabel": "5.3 Creatively Using Digital Technology",
      "name": "Creatively Using Digital Technology",
      "group": "Problem Solving",
      "groupNr": 5,
      "description": "To use digital tools and technologies to create knowledge and to innovate processes and products. to engage individually and collectively in cognitive processing to understand and resolve conceptual problems and problem situations in digital environments."
    },
    {
      "code": "5.4",
      "fullLabel": "5.4 Identifying Digital Competence Gaps",
      "name": "Identifying Digital Competence Gaps",
      "group": "Problem Solving",
      "groupNr": 5,
      "description": "To understand where one's own digital competence needs to be improved or updated. to be able to support others with their digital competence development. to seek opportunities for self-development and to keep up-to-date with the digital evolution."
    }
